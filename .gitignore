**/target
**/*.rs.bk
# Excluded crates have independent Cargo.lock files.
# Boot crate lockfiles ARE tracked — they pin pre-release deps (keccak, sha3)
# that break if Cargo re-resolves freely. CI uses --locked.
# xtask and test-elf lockfiles are not tracked (no fragile pins).
xtask/Cargo.lock
crates/harmony-test-elf/Cargo.lock
*.swp
*.swo
*~
.DS_Store

# Dolt database files (added by bd init)
.dolt/
.beads/*.db

# Direnv cache
.direnv/
